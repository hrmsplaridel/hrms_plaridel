# Miscellaneous
*.class
*.log
analyze_output.txt
final_analyze.txt
flutter_analyze.txt
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# Local environment files and runtime secrets
**/.env
**/.env.*
!**/.env.example
!**/.env.sample

# Server credentials and private cryptographic material
**/*service-account*.json
**/*firebase-adminsdk*.json
**/firebase-admin-key*.json
**/credentials.json
**/.cloudflared/
**/cloudflared/cert.pem
**/cloudflared/*.json
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.crt
**/*.cer

# Android signing secrets
**/key.properties
**/*.keystore
**/*.jks

# Database exports, backups, and local user uploads
**/*.sql.gz
**/*.dump
**/*.backup
**/backups/
**/uploads/

# Local process-manager state and diagnostic output
**/.pm2/
firebase-debug.log

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
