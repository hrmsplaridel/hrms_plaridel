{
  "name": "hrms-plaridel-api",
  "version": "1.0.0",
  "description": "HRMS Plaridel backend - Express + PostgreSQL",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node scripts/free-dev-port.js && node --watch src/index.js",
    "preflight": "node scripts/preflight.js",
    "pm2:deploy": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-pm2.ps1",
    "db:init": "psql -d $npm_config_db -f scripts/init-schema.sql",
    "leave:accrual": "node scripts/run-leave-monthly-accrual.js",
    "leave:accrual:dry": "node scripts/run-leave-monthly-accrual.js --dry-run",
    "llm:smoke": "node scripts/test-llm.js",
    "test:dtr-assistant": "node --test test/dtrAssistantRegression.test.js test/dtrAssistantApi.test.js test/dtrAssistantIntegration.test.js test/dtrAssistantDataService.test.js test/dtrAssistantProviders.test.js test/dtrAssistantDateAndExport.test.js",
    "test:dtr-assistant:regression": "node --test test/dtrAssistantRegression.test.js",
    "eval:intents": "node scripts/eval-intents.js",
    "eval:export-feedback": "node scripts/export-feedback.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emailjs/nodejs": "^5.0.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.1",
    "firebase-admin": "^14.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-zklib": "^1.3.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.12.0",
    "uuid": "^11.1.1",
    "ws": "^8.20.0"
  },
  "overrides": {
    "gaxios": {
      "uuid": "^11.1.1"
    },
    "teeny-request": {
      "uuid": "^11.1.1"
    }
  }
}
