# Copy this file to .env and fill in your values.
# Do not commit .env to version control.

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example (local): postgresql://postgres:yourpassword@localhost:5432/hrms_plaridel
DATABASE_URL=postgresql://localhost:5432/hrms_plaridel

# JWT secret (required for auth). Use a long random string.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production

# Refresh tokens (required for login/register refresh flow). Use a different value than JWT_SECRET.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Server port (default 3000)
PORT=3000

# Server host: 0.0.0.0 = accessible from LAN (other devices on same router)
# Use 127.0.0.1 only if you want localhost-only (no LAN access)
HOST=0.0.0.0

# Access / refresh JWT expiry (optional)
# JWT_EXPIRATION=15m
# JWT_EXPIRY=7d
# JWT_REFRESH_EXPIRATION=30d

# Upload directory for avatars (optional, default backend/uploads)
# UPLOAD_DIR=./uploads

# Biometric sync service: API key for POST /api/biometric-attendance-logs/push
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BIO_SYNC_API_KEY=your-secure-key

# Outgoing email (SMTP) — required for POST /api/rsp/applications/:id/send-hire-email
# Gmail example: use an App Password, SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=api@example.com
# SMTP_PASS=your-smtp-password-or-app-password
# SMTP_FROM="LGU Plaridel HR <hr@example.com>"

# --- EmailJS (optional) — sends mail when POST /api/rsp/applications creates a row.
# Dashboard: https://www.emailjs.com/ — use your Gmail service ID, Account → API keys → Public Key.
#
# REQUIRED for this backend (Node.js): open Account → Security and ALLOW API calls from
# non-browser applications: https://dashboard.emailjs.com/admin/account/security
# Otherwise EmailJS returns HTTP 403 “non-browser environments disabled”.
#
# If you see HTTP 412 / Gmail “insufficient authentication scopes”: EmailJS → Email Services →
# open your Gmail service → reconnect the Google account and accept all permissions (Send email).
#
# EMAILJS_SERVICE_ID=service_xxxxxxx
# EMAILJS_PUBLIC_KEY=your_public_key
# If Account → Security has "Strict mode" (or you get 403: no Private Key), add the Private Key from
# the same API keys page (same place as Public Key). Never commit this to git.
# EMAILJS_PRIVATE_KEY=your_private_key
# HR inbox for "new application" alerts (template "To Email" can be {{hr_email}} or a fixed address in EmailJS):
# EMAILJS_HR_NOTIFY_TO=hr.plaridel@example.com
# Template IDs from EmailJS → Email Templates (create two templates or leave one unset):
# EMAILJS_TEMPLATE_NEW_APPLICATION_ID=template_xxxxxxx
# EMAILJS_TEMPLATE_APPLICANT_CONFIRM_ID=template_yyyyyyy
#
# Hire email (admin "Email applicant" / POST …/send-hire-email). If set with SERVICE_ID + PUBLIC_KEY,
# this is used instead of SMTP. "To Email" in the template = {{to_email}}.
# EMAILJS_TEMPLATE_HIRE_CREDENTIALS_ID=template_zzzzzzz
#
# Parameters passed to templates: applicant_name, applicant_email, applicant_phone,
# position_applied_for, application_id, submitted_at; plus hr_email when EMAILJS_HR_NOTIFY_TO is set;
# plus to_email for the applicant confirmation template (set "To Email" to {{to_email}}).
#
# Hire template parameters: to_email, applicant_name, username, password, account_note.

# Contact Us (landing page form → EmailJS). Template uses: title, name, email, message, time (time is set by API).
# EMAILJS_TEMPLATE_CONTACT_US_ID=template_contact_xxxxx

# RSP Apply (Step 1) — prove the applicant inbox works before POST /api/rsp/applications.
# Same EMAILJS_SERVICE_ID + EMAILJS_PUBLIC_KEY as above (+ EMAILJS_PRIVATE_KEY if strict mode).
# Create an EmailJS template with "To Email" = {{to_email}}; subject/body can use {{verification_code}} and {{expiry_minutes}}.
# When this template ID is set AND JWT_SECRET (or secrets below) is set, Flutter requires Send code → Verify before submit.
# EMAILJS_TEMPLATE_RSP_EMAIL_OTP_ID=template_rsp_email_otp_xxxxx
#
# Template “To Email” = {{to_email}}. Body/subject: {{subject}}, {{to_name}}, {{otp_code}},
# {{expiry_minutes}}, {{expiry_note}} e.g. "This code will expire in 10 minutes."
# (alias {{verification_code}} = otp_code). Optional default subject line string:
# EMAILJS_RSP_OTP_SUBJECT=Verify your email — LGU Plaridel recruitment application
#
# Optional: dedicated key for hashing OTP payloads (otherwise JWT_SECRET).
# RSP_EMAIL_OTP_SECRET=
# Optional: JWT for post-OTP proof token signed by server (otherwise JWT_SECRET).
# RSP_EMAIL_VERIFY_JWT_SECRET=
