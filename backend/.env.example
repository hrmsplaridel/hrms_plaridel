# Copy this file to .env and fill in your values.
# Do not commit .env to version control.

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example (local): postgresql://postgres:yourpassword@localhost:5432/hrms_plaridel
#
# Kamatera VPS + office DB as source of truth: point HOST at the office machine's
# Tailscale IP (100.x.x.x) after VPN is set up — never expose PostgreSQL on the public internet.
# DATABASE_URL=postgresql://postgres:SECRET@100.x.x.x:5432/hrms_plaridel
#
# Optional: longer wait when DB is reached over VPN (default 10000 ms)
# PG_CONNECTION_TIMEOUT_MS=15000
# PG_POOL_MAX=20

DATABASE_URL=postgresql://localhost:5432/hrms_plaridel

# JWT secret (required for auth). Use a long random string.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production

# Refresh tokens (required for login/register refresh flow). Use a different value than JWT_SECRET.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Server port (default 3000)
PORT=3000

# Server host: 0.0.0.0 = accessible from LAN (other devices on same router)
# Use 127.0.0.1 only if you want localhost-only (no LAN access)
HOST=0.0.0.0

# Production on Kamatera behind nginx/Caddy TLS termination — set so Express trusts X-Forwarded-* headers
# TRUST_PROXY=1

# Flutter web only: comma-separated allowed origins (omit for permissive dev). Mobile apps ignore CORS.
# CORS_ORIGINS=https://hrms.example.gov.ph,https://www.example.gov.ph

# Rate limiting (optional; defaults shown)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=300
# AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
# AUTH_LOGIN_RATE_LIMIT_MAX=5
# AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=3600000
# AUTH_REGISTER_RATE_LIMIT_MAX=5
# AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
# AUTH_PASSWORD_RESET_RATE_LIMIT_MAX=3
# AUTH_TOKEN_RATE_LIMIT_WINDOW_MS=900000
# AUTH_TOKEN_RATE_LIMIT_MAX=60
# AUTH_PASSWORD_CHANGE_RATE_LIMIT_WINDOW_MS=900000
# AUTH_PASSWORD_CHANGE_RATE_LIMIT_MAX=5

# Access / refresh JWT expiry (optional)
# JWT_EXPIRATION=15m
# JWT_EXPIRY=7d
# JWT_REFRESH_EXPIRATION=30d

# Upload directory for avatars (optional, default backend/uploads)
# UPLOAD_DIR=./uploads

# Biometric sync service: API key for POST /api/biometric-attendance-logs/push
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BIO_SYNC_API_KEY=your-secure-key

# Outgoing email (SMTP) — required for POST /api/rsp/applications/:id/send-hire-email
# Gmail example: use an App Password, SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=api@example.com
# SMTP_PASS=your-smtp-password-or-app-password
# SMTP_FROM="LGU Plaridel HR <hr@example.com>"
